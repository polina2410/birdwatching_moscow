datasource db {
  provider = "postgresql"
  // url is configured in prisma.config.ts, not here (Prisma 7)
}

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

enum Role {
  USER
  ADMIN
}

enum EventType {
  WALK
  EXPEDITION
}

enum EventStatus {
  DRAFT
  ACTIVE
  CANCELLED
  DELETED
}

enum OrderStatus {
  PENDING
  AWAITING_PAYMENT
  PAID
  FAILED
  EXPIRED
}

enum RequestType {
  PRIVATE_WALK
  EXPEDITION
}

enum RequestStatus {
  NEW
  WAITLIST
}

model User {
  id           String    @id @default(uuid())
  // NOTE: NOT @unique — uniqueness is a partial index WHERE "deletedAt" IS NULL, added via raw SQL in migration
  email        String    @db.VarChar(254)
  passwordHash String
  name         String    @db.VarChar(50)
  role         Role      @default(USER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  orders          Order[]
  tickets         Ticket[]
  cartItems       CartItem[]
  publishedEvents Event[]    @relation("EventPublisher")
}

model Event {
  id           String      @id @default(uuid())
  type         EventType
  slug         String      @unique @db.VarChar(200)
  title        String      @db.VarChar(150)
  description  String      @db.Text
  startsAt     DateTime
  location     String      @db.VarChar(100)
  // NOTE: required for WALK, must be null for EXPEDITION — enforced in app logic
  priceKopecks Int?
  // NOTE: required for WALK, must be null for EXPEDITION — enforced in app logic
  capacity     Int?
  birdSpecies  String[]
  // NOTE: required for EXPEDITION, must be null for WALK — enforced in app logic
  totalSpots   Int?
  // NOTE: required for EXPEDITION, must be null for WALK — enforced in app logic
  spotsLeft    Int?
  status       EventStatus @default(DRAFT)
  coverPhotoUrl String     @db.VarChar(2048)
  galleryUrls  String[]
  publishedAt  DateTime?
  publishedBy  String?

  publisher  User?           @relation("EventPublisher", fields: [publishedBy], references: [id])
  days       ExpeditionDay[]
  guides     TeamMember[]
  tickets    Ticket[]
  cartItems  CartItem[]
  requests   Request[]

  // Matches the public walk list query: type = WALK AND status = ACTIVE AND startsAt >= now, sorted by startsAt
  @@index([type, status, startsAt])
}

model ExpeditionDay {
  id          String @id @default(uuid())
  eventId     String
  dayNumber   Int
  title       String @db.VarChar(150)
  description String @db.Text

  event Event @relation(fields: [eventId], references: [id])
}

model TeamMember {
  id           String   @id @default(uuid())
  name         String   @db.VarChar(50)
  photoUrl     String   @db.VarChar(2048)
  education    String?  @db.Text
  achievements String?  @db.Text
  profileLinks String[]
  sortOrder    Int

  events Event[]
}

model Order {
  id                String      @id @default(uuid())
  userId            String
  status            OrderStatus @default(PENDING)
  totalKopecks      Int
  // NOTE: unique index supports idempotent webhook matching — ЮKassa may deliver the same event twice
  yooKassaPaymentId String?     @unique @db.VarChar(100)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  user    User     @relation(fields: [userId], references: [id])
  tickets Ticket[]
}

model Ticket {
  id        String   @id @default(uuid())
  orderId   String
  userId    String
  eventId   String
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])
  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  @@index([userId])
}

model CartItem {
  id            String   @id @default(uuid())
  userId        String
  eventId       String
  quantity      Int
  // Set by app to now + 20 min. Active reservation = reservedUntil > now; expired rows filtered lazily on read.
  reservedUntil DateTime
  createdAt     DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  @@index([reservedUntil])
}

model Request {
  id        String        @id @default(uuid())
  type      RequestType
  status    RequestStatus @default(NEW)
  // NOTE: set for EXPEDITION requests, null for PRIVATE_WALK
  eventId   String?
  firstName String        @db.VarChar(50)
  lastName  String        @db.VarChar(50)
  email     String        @db.VarChar(254)
  message   String        @db.Text
  createdAt DateTime      @default(now())

  event Event? @relation(fields: [eventId], references: [id])
}
