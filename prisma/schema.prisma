datasource db {
  provider = "postgresql"
  // url is configured in prisma.config.ts, not here (Prisma 7)
}

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

enum Role {
  USER
  ADMIN
  SUPERADMIN
}

enum EventStatus {
  DRAFT
  ACTIVE
  CANCELLED
  DELETED
}

enum OrderStatus {
  PENDING
  AWAITING_PAYMENT
  PAID
  FAILED
  EXPIRED
}

enum RequestType {
  PRIVATE_WALK
  EXPEDITION
}

enum RequestStatus {
  NEW
  WAITLIST
}

model User {
  id           String    @id @default(uuid())
  // NOTE: NOT @unique — uniqueness is a partial index WHERE "deletedAt" IS NULL, added via raw SQL in migration
  email        String    @db.VarChar(254)
  passwordHash String
  name         String    @db.VarChar(50)
  role         Role      @default(USER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  blockedAt    DateTime?

  orders               Order[]
  tickets              Ticket[]
  cartItems            CartItem[]
  publishedWalks       Walk[]               @relation("WalkPublisher")
  publishedExpeditions Expedition[]         @relation("ExpeditionPublisher")
  passwordResetTokens  PasswordResetToken[]
  roleChangesAsTarget  RoleChangeLog[]      @relation("RoleChangeTarget")
  roleChangesAsChanger RoleChangeLog[]      @relation("RoleChangeChanger")
}

model Walk {
  id            String      @id @default(uuid())
  slug          String      @unique @db.VarChar(200)
  title         String      @db.VarChar(150)
  description   String      @db.Text
  startsAt      DateTime
  duration      String?     @db.VarChar(100)
  location      String      @db.VarChar(100)
  priceKopecks  Int
  capacity      Int
  guideId       Int
  status        EventStatus @default(DRAFT)
  coverPhotoUrl String      @db.VarChar(2048)
  publishedAt   DateTime?
  publishedBy   String?
  createdAt     DateTime    @default(now())

  guide     TeamMember @relation(fields: [guideId], references: [id])
  publisher User?      @relation("WalkPublisher", fields: [publishedBy], references: [id])
  tickets   Ticket[]
  cartItems CartItem[]

  @@index([status, startsAt])
}

model Expedition {
  id            String      @id @default(uuid())
  slug          String      @unique @db.VarChar(200)
  title         String      @db.VarChar(150)
  description   String      @db.Text
  startsAt      DateTime
  endsAt        DateTime?
  location      String      @db.VarChar(100)
  totalSpots    Int
  spotsLeft     Int
  status        EventStatus @default(DRAFT)
  coverPhotoUrl String      @db.VarChar(2048)
  publishedAt   DateTime?
  publishedBy   String?
  createdAt     DateTime    @default(now())

  guides    TeamMember[]
  publisher User?          @relation("ExpeditionPublisher", fields: [publishedBy], references: [id])
  days      ExpeditionDay[]
  requests  Request[]

  @@index([status, startsAt])
}

model ExpeditionDay {
  id           String @id @default(uuid())
  expeditionId String
  dayNumber    Int
  title        String @db.VarChar(150)
  description  String @db.Text

  expedition Expedition @relation(fields: [expeditionId], references: [id])
}

model TeamMember {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(50)
  photoUrl     String   @db.VarChar(2048)
  education    String?  @db.Text
  achievements String?  @db.Text
  profileLinks String[]
  sortOrder    Int

  walks       Walk[]
  expeditions Expedition[]
}

model Order {
  id                String      @id @default(uuid())
  userId            String
  status            OrderStatus @default(PENDING)
  totalKopecks      Int
  // NOTE: unique index supports idempotent webhook matching — ЮKassa may deliver the same event twice
  yooKassaPaymentId String?     @unique @db.VarChar(100)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  user    User     @relation(fields: [userId], references: [id])
  tickets Ticket[]
}

model Ticket {
  id        String   @id @default(uuid())
  orderId   String
  userId    String
  walkId    String
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])
  user  User  @relation(fields: [userId], references: [id])
  walk  Walk  @relation(fields: [walkId], references: [id])

  @@index([userId])
}

model CartItem {
  id            String   @id @default(uuid())
  userId        String
  walkId        String
  quantity      Int
  // Set by app to now + 20 min. Active reservation = reservedUntil > now; expired rows filtered lazily on read.
  reservedUntil DateTime
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  walk Walk @relation(fields: [walkId], references: [id])

  @@index([reservedUntil])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique @db.VarChar(64)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Request {
  id           String        @id @default(uuid())
  type         RequestType
  // NOTE: set for EXPEDITION requests, null for PRIVATE_WALK
  expeditionId String?
  name         String        @db.VarChar(100)
  email        String        @db.VarChar(254)
  message      String        @db.Text
  status       RequestStatus @default(NEW)
  createdAt    DateTime      @default(now())

  expedition Expedition? @relation(fields: [expeditionId], references: [id])

  @@index([status])
}

model RoleChangeLog {
  id              String   @id @default(uuid())
  targetUserId    String
  changedByUserId String
  fromRole        Role
  toRole          Role
  createdAt       DateTime @default(now())

  targetUser    User @relation("RoleChangeTarget", fields: [targetUserId], references: [id])
  changedByUser User @relation("RoleChangeChanger", fields: [changedByUserId], references: [id])

  @@index([targetUserId])
  @@index([createdAt])
}
